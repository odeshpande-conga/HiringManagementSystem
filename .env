# ============================================================
# HireFlow - Environment Configuration
# ============================================================
# Copy this file and rename for each environment:
#   .env.local    → Local development
#   .env.azure    → Azure production deployment
# ============================================================

# ---------- Server Configuration ----------
SERVER_PORT=5000
APP_NAME=hiring-management-system

# ---------- Database Configuration ----------
# Local: H2 in-memory (default)
# Azure: Use Azure SQL or PostgreSQL
DB_URL=jdbc:h2:mem:hiringdb
DB_DRIVER=org.h2.Driver
DB_USERNAME=sa
DB_PASSWORD=
DB_PLATFORM=org.hibernate.dialect.H2Dialect
DB_DDL_AUTO=update
DB_SHOW_SQL=true
H2_CONSOLE_ENABLED=true

# ---------- JWT Security ----------
JWT_SECRET=mySecretKeyForHiringManagementSystem12345678
JWT_EXPIRATION=86400000

# ---------- File Upload ----------
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB

# ---------- Azure Specific (for deployment) ----------
# AZURE_SQL_URL=jdbc:sqlserver://<server>.database.windows.net:1433;database=<dbname>;encrypt=true;trustServerCertificate=false;
# AZURE_SQL_USERNAME=
# AZURE_SQL_PASSWORD=
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER_NAME=resumes

# ---------- CORS (set your frontend domain on Azure) ----------
CORS_ALLOWED_ORIGINS=http://localhost:5000

